{
  "name": "analythicc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:dev": "npm run pages:build && wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply analythicc --local",
    "db:migrate:remote": "wrangler d1 migrations apply analythicc --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.5",
    "drizzle-orm": "^0.36.4",
    "next": "15.0.3",
    "react": "19.0.0-rc-66855b96-20241106",
    "react-dom": "19.0.0-rc-66855b96-20241106",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.15.0",
    "eslint-config-next": "15.0.3",
    "postcss": "^8.4.49",
    "puppeteer-core": "^24.40.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vercel": "^37.14.0",
    "wrangler": "^3.87.0"
  }
}
